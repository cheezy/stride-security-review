<?xml version="1.0" encoding="UTF-8"?>
<!--
  Vulnerable iOS Info.plist: ATS disabled globally.

  Trust boundary: NSAllowsArbitraryLoads = true tells the system to accept
  cleartext HTTP and weak TLS configurations EVERYWHERE in the app. No
  NSExceptionDomains allow-list means the developer didn't even constrain
  the exception to specific internal-only hosts. Apple-store-distributed
  apps require justification for ATS exceptions; this is the broadest
  possible exception.

  Expected finding: insecure_config (high), CWE-319, A02:2021.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDisplayName</key>
    <string>MyApp</string>

    <key>CFBundleIdentifier</key>
    <string>com.example.myapp</string>

    <key>NSAppTransportSecurity</key>
    <dict>
        <!-- VULNERABLE: every network call can be cleartext HTTP. -->
        <key>NSAllowsArbitraryLoads</key>
        <true/>

        <!-- Also vulnerable: web-content variant covers WKWebView loads. -->
        <key>NSAllowsArbitraryLoadsInWebContent</key>
        <true/>

        <!-- No NSExceptionDomains allow-list — i.e. no scoping to specific
             internal-only hosts. The whole net is cleartext-eligible. -->
    </dict>
</dict>
</plist>
